---
layout: layouts/blog.njk
pagination:
  data: collections.posts
  size: 12
  alias: postList
permalink: "blog/{% if pagination.pageNumber > 0 %}page/{{ pagination.pageNumber + 1 }}/{% endif %}index.html"
---

{% if postList.length %}
<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
  {% for post in postList %}
  <article class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl overflow-hidden hover:border-blue-300 dark:hover:border-blue-700 hover:shadow-lg transition-all flex flex-col">
    {%- if post.data.image %}
    <a href="{{ post.url }}" class="block" aria-label="{{ post.data.title }}">
      <div class="blog-hero blog-hero-card h-[100px] sm:h-[160px]">
        <img src="{{ post.data.image }}" alt="" width="100" height="100" class="max-h-[60px] sm:max-h-[100px]">
      </div>
    </a>
    {%- endif %}
    <div class="p-4 pt-3 sm:p-6 sm:pt-5 flex flex-col flex-1">
      <div class="flex items-center gap-2 text-xs sm:text-sm text-gray-500 dark:text-gray-500">
        <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
        <span>&middot;</span>
        <span>{{ post.templateContent | readingTime }}</span>
      </div>
      <h2 class="mt-1 sm:mt-2 text-base sm:text-lg font-semibold text-gray-900 dark:text-white">
        <a href="{{ post.url }}" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">{{ post.data.title }}</a>
      </h2>
      <p class="mt-1 sm:mt-2 text-gray-600 dark:text-gray-400 text-xs sm:text-sm leading-relaxed">{{ post.data.description }}</p>
      {%- if post.data.tags %}
      <div class="mt-auto pt-3 sm:pt-4 flex flex-wrap gap-1.5 sm:gap-2">
        {%- for tag in post.data.tags %}{% if tag != "posts" %}
          <span class="text-xs bg-blue-50 dark:bg-blue-950/60 text-blue-700 dark:text-blue-300 px-2 py-0.5 rounded-full">{{ tag }}</span>
        {%- endif %}{% endfor %}
      </div>
      {%- endif %}
    </div>
  </article>
  {% endfor %}
</div>
{% else %}
<p class="text-gray-500 dark:text-gray-400">No posts yet. Check back soon!</p>
{% endif %}

{% if pagination.pages.length > 1 %}
<nav aria-label="Blog pagination" class="mt-12 flex items-center justify-center gap-2">
  {%- if pagination.href.previous %}
  <a href="{{ pagination.href.previous }}" aria-label="Previous page" class="inline-flex items-center justify-center px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors"><svg class="h-5 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg></a>
  {%- else %}
  <span aria-hidden="true" class="inline-flex items-center justify-center px-3 py-2 text-sm font-medium text-gray-300 dark:text-gray-600 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg opacity-50 cursor-default"><svg class="h-5 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg></span>
  {%- endif %}
  {%- for pageEntry in pagination.pages %}
  {%- set pageUrl = pagination.hrefs[loop.index0] %}
  {%- if loop.index0 == pagination.pageNumber %}
  <span class="px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg">{{ loop.index }}</span>
  {%- else %}
  <a href="{{ pageUrl }}" class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">{{ loop.index }}</a>
  {%- endif %}
  {%- endfor %}
  {%- if pagination.href.next %}
  <a href="{{ pagination.href.next }}" aria-label="Next page" class="inline-flex items-center justify-center px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors"><svg class="h-5 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
  {%- else %}
  <span aria-hidden="true" class="inline-flex items-center justify-center px-3 py-2 text-sm font-medium text-gray-300 dark:text-gray-600 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg opacity-50 cursor-default"><svg class="h-5 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></span>
  {%- endif %}
</nav>
{% endif %}
