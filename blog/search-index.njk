[{% for post in collections.posts %}{"title":{{ post.data.title | dump | safe }},"description":{{ post.data.description | dump | safe }},"url":"{{ post.url }}","date":"{{ post.date | readableDate }}","isoDate":"{{ post.date | isoDate }}","tags":[{% for tag in post.data.tags %}{% if tag != "posts" %}"{{ tag }}"{% if not loop.last %},{% endif %}{% endif %}{% endfor %}],"image":"{{ post.data.image or '' }}","readingTime":"{{ post.templateContent | readingTime }}"}{% if not loop.last %},{% endif %}{% endfor %}]
