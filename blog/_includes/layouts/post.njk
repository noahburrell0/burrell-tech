<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Meta -->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | Burrell Technology Services</title>
  <meta name="description" content="{{ description }}">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <link rel="icon" href="/favicon.ico">
  <link rel="preload" href="/fonts/inter-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/logo.png" as="image">

  <!-- Open Graph -->
  <meta property="og:type" content="article">
  <meta property="og:site_name" content="Burrell Technology Services S.A.">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:image" content="https://burrell.tech/logo.png">
  <meta property="article:published_time" content="{{ date | isoDate }}">
  <meta property="article:author" content="{{ site.author }}">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{{ title }}">
  <meta name="twitter:description" content="{{ description }}">
  <meta name="twitter:image" content="https://burrell.tech/logo.png">

  <!-- Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "{{ title }}",
    "datePublished": "{{ date | isoDate }}",
    "description": "{{ description }}",
    "url": "{{ site.url }}{{ page.url }}",
    "author": {
      "@type": "Person",
      "name": "{{ site.author }}",
      "url": "https://burrell.tech/about"
    },
    "publisher": {
      "@id": "https://burrell.tech/#organization"
    }
  }
  </script>

  <!-- Theme (blocking - must run before first paint to prevent flash) -->
  <script src="/js/theme.js"></script>

  <!-- Styles -->
  <link rel="stylesheet" href="/css/tailwind.css">
  <link rel="stylesheet" href="/css/custom.css">

  <!-- Scripts -->
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <script defer src="/js/analytics.js"></script>
</head>
<body class="bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 font-sans antialiased">

  <div id="nav-placeholder" data-active-page="blog"></div>

  <main class="flex-1">
  <!-- Post Header -->
  <section class="bg-gray-50 dark:bg-gray-900/40 border-b border-gray-200 dark:border-gray-800 py-16 sm:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/blog" class="inline-flex items-center gap-1.5 text-sm text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 transition-colors mb-6">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        All posts
      </a>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-gray-900 dark:text-white">{{ title }}</h1>
      <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-gray-500 dark:text-gray-400">
        <time datetime="{{ date | isoDate }}">{{ date | readableDate }}</time>
        <span class="hidden sm:inline">&middot;</span>
        <span>{{ site.author }}</span>
      </div>
      {% if tags %}
      <div class="mt-4 flex flex-wrap gap-2">
        {% for tag in tags %}
          {% if tag != "posts" %}
          <span class="text-xs bg-blue-50 dark:bg-blue-950/60 text-blue-700 dark:text-blue-300 px-2.5 py-1 rounded-full">{{ tag }}</span>
          {% endif %}
        {% endfor %}
      </div>
      {% endif %}
    </div>
  </section>

  <!-- Post Content -->
  <section class="py-12 sm:py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <article class="prose prose-lg dark:prose-invert max-w-none prose-headings:font-bold prose-a:text-blue-600 dark:prose-a:text-blue-400 prose-code:text-sm prose-pre:bg-gray-900 dark:prose-pre:bg-gray-800 prose-img:rounded-xl">
        {{ content | safe }}
      </article>
    </div>
  </section>
  </main>

  <div id="cta-placeholder"
    data-i18n="blog_cta"
    data-variant="simple"></div>
  <div id="footer-placeholder"></div>

  <!-- components.js must run before Alpine (deferred) so nav x-data is in the DOM at Alpine init time -->
  <script src="/js/components.js"></script>
  <script src="/js/main.js"></script>
  <script>
  // Rewrite internal links in blog posts to respect stored language preference
  (function () {
    var lang = localStorage.getItem('lang');
    if (lang !== 'es') return;
    var links = document.querySelectorAll('article a[href]');
    for (var i = 0; i < links.length; i++) {
      var href = links[i].getAttribute('href');
      if (href && href.charAt(0) === '/' && !href.match(/^\/blog(\/|$)/) && !href.match(/^\/(css|js|fonts)\//)) {
        links[i].setAttribute('href', '/es' + href);
      }
    }
  })();
  </script>
</body>
</html>
