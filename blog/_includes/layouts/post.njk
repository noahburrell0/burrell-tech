{% extends "layouts/base.njk" %}

{% block title %}{{ title }} | Burrell Technology Services{% endblock %}
{% block description %}{{ description }}{% endblock %}
{% block canonical %}{{ site.url }}{{ page.url }}{% endblock %}

{%- block meta %}
  <!-- Open Graph -->
  {%- set ogSlug = page.inputPath | postSlug %}
  {%- set ogImage = site.url + "/blog/og/" + ogSlug + ".png" %}
  <meta property="og:type" content="article">
  <meta property="og:site_name" content="Burrell Technology Services S.A.">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:image" content="{{ ogImage }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="article:published_time" content="{{ date | isoDate }}">
  <meta property="article:modified_time" content="{{ modified | isoDate if modified else date | isoDate }}">
  <meta property="article:author" content="{{ site.author }}">
  {%- if tags %}{% for tag in tags %}{% if tag != "posts" %}
  <meta property="article:tag" content="{{ tag }}">
  {%- endif %}{% endfor %}{% endif %}
  {%- set nonPostTags = tags | reject("equalto", "posts") | list %}
  {%- if nonPostTags | length %}
  <meta property="article:section" content="{{ nonPostTags | first }}">
  {%- endif %}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }}">
  <meta name="twitter:description" content="{{ description }}">
  <meta name="twitter:image" content="{{ ogImage }}">

  <!-- Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "{{ title }}",
    "datePublished": "{{ date | isoDate }}",
    "dateModified": "{{ modified | isoDate if modified else date | isoDate }}",
    "description": "{{ description }}",
    "url": "{{ site.url }}{{ page.url }}",
    "image": "{{ ogImage }}",
    "timeRequired": "PT{{ content | readingTime | replace(' min read', '') }}M",
    "author": {
      "@type": "Person",
      "name": "{{ site.author }}",
      "url": "https://burrell.tech/about"
    },
    "publisher": {
      "@id": "https://burrell.tech/#organization"
    }{%- if tags %},
    "keywords": "{{ tags | reject("equalto", "posts") | join(', ') }}"{% endif %}
  }
  </script>
{%- endblock %}

{%- block body %}
  <main class="flex-1">
  <!-- Post Header -->
  <section class="bg-gray-50 dark:bg-gray-900/40 border-b border-gray-200 dark:border-gray-800 py-16 sm:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/blog" class="inline-flex items-center gap-1.5 text-sm text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 transition-colors mb-6">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        All posts
      </a>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-gray-900 dark:text-white">{{ title }}</h1>
      <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-gray-500 dark:text-gray-400">
        <time datetime="{{ date | isoDate }}">{{ date | readableDate }}</time>
        <span>&middot;</span>
        <span>{{ site.author }}</span>
        <span>&middot;</span>
        <span>{{ content | readingTime }}</span>
      </div>
      {%- if tags %}
      <div class="mt-4 flex flex-wrap gap-2">
        {%- for tag in tags %}{% if tag != "posts" %}
          <span class="text-xs bg-blue-50 dark:bg-blue-950/60 text-blue-700 dark:text-blue-300 px-2.5 py-1 rounded-full">{{ tag }}</span>
        {%- endif %}{% endfor %}
      </div>
      {%- endif %}
    </div>
  </section>

  <!-- Post Content -->
  <section class="py-12 sm:py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <article class="prose prose-lg dark:prose-invert max-w-none prose-headings:font-bold prose-a:text-blue-600 dark:prose-a:text-blue-400 prose-code:text-sm prose-pre:bg-gray-100 prose-pre:border prose-pre:border-gray-200 dark:prose-pre:bg-gray-800 dark:prose-pre:border-gray-700 prose-img:rounded-xl">
        {{ content | safe }}
      </article>
    </div>
  </section>
  </main>

  <div id="cta-placeholder"
    data-i18n="blog_cta"
    data-variant="simple"></div>
{%- endblock %}
{%- block scripts %}
  <script src="/js/blog-i18n-links.js"></script>
  <script src="/js/code-copy.js"></script>
  <script src="/js/mermaid.js" type="module"></script>
{%- endblock -%}