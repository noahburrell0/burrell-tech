<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Meta -->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{%- block title %}Blog | Burrell Technology Services{% endblock -%}</title>
  <meta name="description" content="{%- block description %}Articles on Kubernetes, Argo CD, GitOps, and cloud-native infrastructure by Noah Burrell.{% endblock -%}">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="{%- block canonical %}{{ site.url }}/blog/{% endblock -%}">
  <link rel="icon" href="/favicon.ico">
  <link rel="preload" href="/fonts/inter-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/logo.webp" as="image">
{% block meta %}{% endblock %}

  <!-- Theme (blocking - must run before first paint to prevent flash) -->
  <script src="/js/theme.js"></script>

  <!-- Styles -->
  <link rel="stylesheet" href="/css/tailwind.css">
  <link rel="stylesheet" href="/css/custom.css">

  <!-- Scripts -->
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <script defer src="/js/analytics.js"></script>
</head>
<body class="bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 font-sans antialiased">

  <div id="nav-placeholder" data-active-page="blog" style="min-height:64px"></div>
{% block body %}{% endblock %}
  <div id="footer-placeholder" style="min-height:200px"></div>

  <!-- components.js must run before Alpine (deferred) so nav x-data is in the DOM at Alpine init time -->
  <script src="/js/components.js"></script>
  <script src="/js/main.js"></script>
{%- block scripts %}{% endblock %}
</body>
</html>
