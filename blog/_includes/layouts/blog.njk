<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Meta -->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Blog | Burrell Technology Services</title>
  <meta name="description" content="Articles on Kubernetes, Argo CD, GitOps, and cloud-native infrastructure by Noah Burrell.">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="{{ site.url }}/blog/">
  <link rel="icon" href="/favicon.ico">
  <link rel="preload" href="/fonts/inter-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin>

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Burrell Technology Services S.A.">
  <meta property="og:title" content="Blog | Burrell Technology Services">
  <meta property="og:description" content="Articles on Kubernetes, Argo CD, GitOps, and cloud-native infrastructure by Noah Burrell.">
  <meta property="og:url" content="{{ site.url }}/blog/">
  <meta property="og:image" content="https://burrell.tech/logo.png">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="Blog | Burrell Technology Services">
  <meta name="twitter:description" content="Articles on Kubernetes, Argo CD, GitOps, and cloud-native infrastructure by Noah Burrell.">
  <meta name="twitter:image" content="https://burrell.tech/logo.png">

  <!-- Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "Burrell Technology Services Blog",
    "description": "Articles on Kubernetes, Argo CD, GitOps, and cloud-native infrastructure.",
    "url": "{{ site.url }}/blog/",
    "author": {
      "@type": "Person",
      "name": "{{ site.author }}",
      "url": "https://burrell.tech/about"
    },
    "publisher": {
      "@id": "https://burrell.tech/#organization"
    }
  }
  </script>

  <!-- Theme (blocking - must run before first paint to prevent flash) -->
  <script src="/js/theme.js"></script>

  <!-- Styles -->
  <link rel="stylesheet" href="/css/tailwind.css">
  <link rel="stylesheet" href="/css/custom.css">

  <!-- Scripts -->
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <script defer src="/js/analytics.js"></script>
</head>
<body class="bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 font-sans antialiased">

  <div id="nav-placeholder" data-active-page="blog"></div>

  <main class="flex-1">
  <!-- Page Header -->
  <section class="bg-gray-50 dark:bg-gray-900/40 border-b border-gray-200 dark:border-gray-800 py-16 sm:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-gray-900 dark:text-white">Blog</h1>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400 max-w-2xl">Articles on Kubernetes, Argo CD, GitOps, and cloud-native infrastructure.</p>
    </div>
  </section>

  <!-- Posts Grid -->
  <section class="py-12 sm:py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      {% set postList = collections.posts %}
      {% if postList.length %}
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {% for post in postList %}
        <article class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl p-8 hover:border-blue-300 dark:hover:border-blue-700 hover:shadow-lg transition-all">
          <time datetime="{{ post.date | isoDate }}" class="text-sm text-gray-500 dark:text-gray-500">{{ post.date | readableDate }}</time>
          <h2 class="mt-2 text-lg font-semibold text-gray-900 dark:text-white">
            <a href="{{ post.url }}" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">{{ post.data.title }}</a>
          </h2>
          <p class="mt-2 text-gray-600 dark:text-gray-400 text-sm leading-relaxed">{{ post.data.description }}</p>
          {% if post.data.tags %}
          <div class="mt-4 flex flex-wrap gap-2">
            {% for tag in post.data.tags %}
              {% if tag != "posts" %}
              <span class="text-xs bg-blue-50 dark:bg-blue-950/60 text-blue-700 dark:text-blue-300 px-2 py-0.5 rounded-full">{{ tag }}</span>
              {% endif %}
            {% endfor %}
          </div>
          {% endif %}
        </article>
        {% endfor %}
      </div>
      {% else %}
      <p class="text-gray-500 dark:text-gray-400">No posts yet. Check back soon!</p>
      {% endif %}
    </div>
  </section>
  </main>

  <div id="footer-placeholder"></div>

  <!-- components.js must run before Alpine (deferred) so nav x-data is in the DOM at Alpine init time -->
  <script src="/js/components.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
